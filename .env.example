# Copy to .env and fill in. LLM: set ONE key (fallback order: anthropic > google > openai),
# or pin explicitly with PRISM_MODEL.

# Anthropic (https://console.anthropic.com/settings/keys) - needs credits
ANTHROPIC_API_KEY=
# Google Gemini - free tier available, no card: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
# Optional explicit model, e.g. "openai:gpt-5.1", "google:gemini-3.5-flash", "anthropic:claude-sonnet-4-6"
# PRISM_MODEL=

# Trigger.dev DEV secret key (free): https://cloud.trigger.dev -> your project -> API keys (tr_dev_...)
TRIGGER_SECRET_KEY=

# Local ClickHouse (matches docker-compose.yml)
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=canvas
CLICKHOUSE_PASSWORD=canvas
CLICKHOUSE_DATABASE=canvas
